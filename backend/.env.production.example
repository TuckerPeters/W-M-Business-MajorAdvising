# ===========================================
# Heroku Environment Variables (Config Vars)
# Set these via: heroku config:set KEY=VALUE
# Or in the Heroku dashboard under Settings > Config Vars
# ===========================================

# Frontend URL for CORS (your Netlify site URL)
FRONTEND_URL=https://your-site-name.netlify.app

# Firebase Service Account (paste the ENTIRE JSON content of your service account key)
# Get this from: Firebase Console > Project Settings > Service Accounts > Generate new private key
# Then run: heroku config:set FIREBASE_SERVICE_ACCOUNT_JSON='$(cat serviceAccountKey.json)'
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"premajorandmajoradvising",...}

# Firebase Project ID
FIREBASE_PROJECT_ID=premajorandmajoradvising

# OpenAI API Key (for AI chat features)
OPENAI_API_KEY=sk-proj-your-key-here

# API Configuration
API_CONTACT_EMAIL=admin@wm.edu

# Email domain restriction (optional, defaults to wm.edu)
ALLOWED_EMAIL_DOMAIN=wm.edu

# Redis Cache (optional - Heroku Redis addon)
# REDIS_URL=redis://... (auto-set by Heroku Redis addon)
