# ===========================================
# Netlify Environment Variables
# Set these in the Netlify dashboard under:
# Site settings > Build & deploy > Environment
# ===========================================

# Backend URL (your Heroku app URL)
NEXT_PUBLIC_BACKEND_URL=https://your-app-name.herokuapp.com
NEXT_PUBLIC_API_URL=https://your-app-name.herokuapp.com

# Firebase Web SDK Config (from Firebase Console > Project Settings > General)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=premajorandmajoradvising.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=premajorandmajoradvising
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=premajorandmajoradvising.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Feature Flags
NEXT_PUBLIC_USE_MOCK_DATA_FALLBACK=false
NEXT_PUBLIC_ENABLE_COURSE_SEARCH=true
